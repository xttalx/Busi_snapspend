# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL (used for auth redirects and billing checkout return URLs)
NEXT_PUBLIC_SITE_URL=https://martenbooks.com

# Billing — off by default (email sign-in only). Set BILLING_ENABLED=true to enable Pro / pay-per-download.
BILLING_ENABLED=

# Lemon Squeezy — https://docs.lemonsqueezy.com (signed-in app billing)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Variant IDs from Lemon Squeezy dashboard (Products → Variant)
LEMONSQUEEZY_VARIANT_PRO_MONTHLY=
LEMONSQUEEZY_VARIANT_PAY_PER_DOWNLOAD=
# Optional: $0 (or minimal) product to capture card at signup for pay-per-download users
LEMONSQUEEZY_VARIANT_CARD_SETUP=

# Stripe — guest pay-per-download at /invoice (only when BILLING_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint: https://your-domain.com/api/billing/stripe-webhook
# Events: checkout.session.completed
